# ── Snowflake ─────────────────────────────────────────────────────────────────
# Your Snowflake account identifier (e.g. myorg-myaccount)
SNOWFLAKE_ACCOUNT=your-account

# Your Snowflake username (usually your email)
SNOWFLAKE_USER=you@yourorg.com

# externalbrowser = SSO/OAuth popup (good for manual runs)
# snowflake_jwt   = key-pair auth (required for scheduled/unattended runs)
SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Warehouse to use for queries
SNOWFLAKE_WAREHOUSE=your_warehouse

# Database and schema where output tables will be written
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema

# Optional: Snowflake role to use
SNOWFLAKE_ROLE=your_role

# The fully-qualified CMS articles table in Snowflake.
# See load_arc() in pipeline.py for required columns and how to rename them
# if your schema uses different column names.
ARC_TABLE=your_database.your_schema.your_articles_table

# ── Publication identity (used in the Cortex matching prompt) ─────────────────
# These help the LLM resolve ambiguous queries correctly.
# Example: PUBLICATION_NAME=The Daily Bugle
#          PUBLICATION_LOCATION=New York City
PUBLICATION_NAME=Your Publication Name
PUBLICATION_LOCATION=Your City or Region

# ── Google Search Console ──────────────────────────────────────────────────────
# Path to your GCP service account JSON key file
# See: https://developers.google.com/webmaster-tools/v1/how-tos/authorizing
GSC_SERVICE_ACCOUNT_FILE=/path/to/your-service-account-key.json

# Your site as it appears in Google Search Console (include trailing slash)
GSC_SITE_URL=https://www.yoursite.com/

# ── BigQuery (untested mirror — only used by *_bigquery.py) ───────────────────
# These variables are ONLY needed if you run the BigQuery scripts
# (pipeline_bigquery.py, gsc_pull_bigquery.py, load_gsc_csv_bigquery.py).
# The Snowflake path above is what's been run in production. The
# BigQuery mirror has not been run end-to-end — expect to debug.
#
# Auth: uses Application Default Credentials by default. For unattended runs
# set GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json or use Workload Identity.

# Your GCP project ID
GCP_PROJECT=your-gcp-project

# Location/region for BigQuery jobs (must match your dataset location)
BQ_LOCATION=US

# Dataset where output tables will be written
BQ_DATASET=trend_tracker

# Fully-qualified CMS articles table in BigQuery (project.dataset.table).
# See load_arc() in pipeline_bigquery.py for required columns.
BQ_ARC_TABLE=your-gcp-project.your_dataset.your_articles_table

# Remote Gemini model for ML.GENERATE_TEXT (the Cortex analog).
# Requires one-time setup: BQ Connection + CREATE MODEL — see README.
# Falls back to pure Jaccard matching if this model is not configured.
BQ_GEMINI_MODEL=your-gcp-project.your_dataset.gemini_model
